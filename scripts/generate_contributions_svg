#!/usr/bin/env ruby
# frozen_string_literal: true

# Generate per-year contribution heatmap SVGs and a preview HTML page.
#
# Reads raw JSON from contributions/data/YYYY.json (produced by fetch_contributions.rb).
# Layout per year: 6 rows x 2 columns (H1: Jan-Jun, H2: Jul-Dec).
# Thresholds computed globally so colors are consistent across years.
#
# Output:
#   contributions/YYYY.svg         (one per year)
#   contributions/month-labels.svg
#   contributions/preview.html
#
# Usage:
#   ruby scripts/generate_svg.rb

require "json"

DATA_DIR = File.expand_path("../images/contributions/data", __dir__)
OUT_DIR  = File.expand_path("../images/contributions", __dir__)

COLORS = {
  0 => "#ebedf0",
  1 => "#9be9a8",
  2 => "#40c463",
  3 => "#30a14e",
  4 => "#216e39",
}

CELL_SIZE   = 14
CELL_GAP    = 3
CELL_STEP   = CELL_SIZE + CELL_GAP
YEAR_LABEL_HEIGHT = 16
FONT_SIZE   = 11
FONT_FAMILY = "-apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif"

MONTH_NAMES = %w[Jan Feb Mar Apr May Jun Jul Aug Sep Oct Nov Dec]

# --- data ---

def load_data
  years = {}
  totals = { contributions: 0, commits: 0, prs: 0, reviews: 0, issues: 0, repos: Set.new, repo_commits: Hash.new(0) }

  Dir.glob(File.join(DATA_DIR, "*.json")).sort.each do |f|
    year = File.basename(f, ".json").to_i
    raw = JSON.parse(File.read(f))
    days = raw["contributionCalendar"]["weeks"].flat_map { |w| w["contributionDays"] }

    months = Hash.new(0)
    days.each { |d| months[d["date"][5..6].to_i] += d["contributionCount"] }

    years[year] = months

    totals[:contributions] += raw["contributionCalendar"]["totalContributions"]
    totals[:commits] += raw["totalCommitContributions"]
    totals[:prs] += raw["totalPullRequestContributions"]
    totals[:reviews] += raw["totalPullRequestReviewContributions"]
    totals[:issues] += raw["totalIssueContributions"]
    raw["commitContributionsByRepository"].each do |r|
      name = r["repository"]["nameWithOwner"]
      totals[:repos] << name
      totals[:repo_commits][name] += r["contributions"]["totalCount"]
    end
  end

  totals[:repos] = totals[:repos].size
  [years.sort_by(&:first), totals]
end

# --- color ---

def compute_thresholds(all_counts)
  nonzero = all_counts.select { |c| c > 0 }.sort
  return [1, 2, 3] if nonzero.empty?
  q = ->(pct) { nonzero[(nonzero.length * pct).floor] }
  [q[0.25], q[0.50], q[0.75]]
end

def color_level(count, thresholds)
  return 0 if count == 0
  return 1 if count <= thresholds[0]
  return 2 if count <= thresholds[1]
  return 3 if count <= thresholds[2]
  4
end

def escape_xml(s)
  s.gsub("&", "&amp;").gsub("<", "&lt;").gsub(">", "&gt;")
end

# --- SVG generators ---

MONTH_LABEL_WIDTH = 28

def year_svg(year, months, thresholds, show_label: false, first: false)
  cell_w = 2 * CELL_STEP - CELL_GAP
  left = first ? MONTH_LABEL_WIDTH : 0
  w = left + cell_w
  h = YEAR_LABEL_HEIGHT + 6 * CELL_STEP - CELL_GAP

  lines = []
  lines << %(<svg xmlns="http://www.w3.org/2000/svg" width="#{w}" height="#{h}" viewBox="0 0 #{w} #{h}" style="overflow:visible">)
  lines << %(<style>text{font-family:#{FONT_FAMILY};font-size:#{FONT_SIZE}px;fill:#57606a}rect.c:hover{stroke:#1b1f23;stroke-width:1}</style>)

  if first
    { 0 => "Jan", 2 => "Mar", 3 => "Oct", 5 => "Dec" }.each do |row, label|
      y = YEAR_LABEL_HEIGHT + row * CELL_STEP + CELL_SIZE / 2 + 4
      lines << %(<text x="0" y="#{y}">#{label}</text>)
    end
  end

  if show_label
    lines << %(<text x="#{left + cell_w / 2.0}" y="#{YEAR_LABEL_HEIGHT - 3}" text-anchor="middle">#{year}</text>)
  end

  (1..12).each do |m|
    col = m <= 6 ? 0 : 1
    row = m <= 6 ? m - 1 : m - 7
    count = months[m] || 0
    color = COLORS[color_level(count, thresholds)]
    x = left + col * CELL_STEP
    y = YEAR_LABEL_HEIGHT + row * CELL_STEP
    tip = "#{count} contribution#{count == 1 ? "" : "s"} in #{MONTH_NAMES[m - 1]} #{year}"
    lines << %(<rect class="c" x="#{x}" y="#{y}" width="#{CELL_SIZE}" height="#{CELL_SIZE}" rx="2" ry="2" fill="#{color}"><title>#{escape_xml(tip)}</title></rect>)
  end

  lines << %(</svg>)
  lines.join("\n") + "\n"
end

# --- stats SVG ---

def format_count(n)
  n.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1,').reverse
end

def stats_svg(totals)
  # Diamond: top=Code reviews, right=Issues, bottom=Pull requests, left=Commits
  w = 300
  h = 230
  cx = w / 2.0
  cy = h / 2.0 + 5
  radius = 70
  font = 13

  # Order: top, right, bottom, left
  values = [totals[:reviews], totals[:issues], totals[:prs], totals[:commits]]
  max_val = values.max.to_f
  norms = values.map { |v| v == 0 ? 0.0 : 0.15 + 0.85 * (v / max_val) }

  dirs = [[0, -1], [1, 0], [0, 1], [-1, 0]]
  shape = dirs.each_with_index.map { |(dx, dy), i| [cx + dx * radius * norms[i], cy + dy * radius * norms[i]] }

  labels = [
    { text: "Code reviews",  count: totals[:reviews], x: cx,               y_count: cy - radius - 20, y_text: cy - radius - 6, anchor: "middle" },
    { text: "Issues",        count: totals[:issues],  x: cx + radius + 8,  y_count: cy - 2,           y_text: cy + 14,         anchor: "start" },
    { text: "Pull requests", count: totals[:prs],     x: cx,               y_count: cy + radius + 16, y_text: cy + radius + 30, anchor: "middle" },
    { text: "Commits",       count: totals[:commits], x: cx - radius - 8,  y_count: cy - 2,           y_text: cy + 14,         anchor: "end" },
  ]

  lines = []
  lines << %(<svg xmlns="http://www.w3.org/2000/svg" width="#{w}" height="#{h}" viewBox="0 0 #{w} #{h}">)
  lines << %(<style>)
  lines << %(  text { font-family: #{FONT_FAMILY}; font-size: #{font}px; fill: #57606a; })
  lines << %(  .count { font-weight: 600; })
  lines << %(</style>)

  # Axis lines (dark green like GitHub's original)
  dirs.each do |dx, dy|
    lines << %(<line x1="#{cx}" y1="#{cy}" x2="#{cx + dx * radius}" y2="#{cy + dy * radius}" stroke="#30a14e" stroke-width="1.5" />)
  end

  # Axis endpoints
  dirs.each do |dx, dy|
    lines << %(<circle cx="#{cx + dx * radius}" cy="#{cy + dy * radius}" r="3" fill="none" stroke="#30a14e" stroke-width="1.5" />)
  end

  # Data shape
  pts = shape.map { |x, y| "#{x},#{y}" }.join(" ")
  lines << %(<polygon points="#{pts}" fill="rgba(64, 196, 99, 0.25)" stroke="#40c463" stroke-width="2" />)

  # Data points
  shape.each do |x, y|
    lines << %(<circle cx="#{x}" cy="#{y}" r="3" fill="#40c463" />)
  end

  # Labels: count on one line, text below
  labels.each do |l|
    lines << %(<text x="#{l[:x]}" y="#{l[:y_count]}" text-anchor="#{l[:anchor]}" class="count">#{format_count(l[:count])}</text>)
    lines << %(<text x="#{l[:x]}" y="#{l[:y_text]}" text-anchor="#{l[:anchor]}">#{l[:text]}</text>)
  end

  lines << %(</svg>)
  lines.join("\n") + "\n"
end

# --- README snippet ---

IMG_PREFIX = "images/contributions"

def readme_snippet(year_data)
  lines = []
  year_data.each do |year, months|
    total = (1..12).sum { |m| months[m] || 0 }
    url = "https://github.com/kbrock?tab=overview&from=#{year}-01-01&to=#{year}-12-31"
    lines << %(<a href="#{url}" title="#{total} contributions in #{year}"><img src="#{IMG_PREFIX}/#{year}.svg" alt="#{year}" /></a>)
  end

  lines.join("\n")
end

CURATED_REPOS = [
  { name: "manageiq",            repo: "ManageIQ/manageiq",                          gem: nil,                              maintain: false },
  { name: "ancestry",            repo: "stefankroes/ancestry",                       gem: "ancestry",                       maintain: true },
  { name: "active_hash",         repo: "active-hash/active_hash",                    gem: "active_hash",                    maintain: true },
  { name: "optimist",            repo: "ManageIQ/optimist",                          gem: "optimist",                       maintain: true },
  { name: "virtual_attributes",  repo: "ManageIQ/activerecord-virtual_attributes",   gem: "activerecord-virtual_attributes", maintain: true },
  { name: "floe",                repo: "ManageIQ/floe",                              gem: "floe",                           maintain: false },
  { name: "ruport",              repo: "ruport/ruport",                              gem: "ruport",                         maintain: false },
  { name: "rails",               repo: "rails/rails",                                gem: nil,                              maintain: false },
]

def activity_overview(totals)
  lines = []
  lines << %(<table><tr><td valign="top">)
  lines << ""
  lines << "**Contributed to**"
  lines << ""
  CURATED_REPOS.each do |r|
    count = totals[:repo_commits][r[:repo]] || 0
    encoded_count = format_count(count).gsub(",", "%2C")
    name = r[:maintain] ? "**#{r[:name]}**" : r[:name]
    link = "[#{name}](https://github.com/#{r[:repo]})"
    commit_badge = "![](https://img.shields.io/badge/#{encoded_count}-commits-blue?style=flat-square&logo=git&logoColor=white)"
    if r[:gem]
      dl_badge = "![](https://img.shields.io/gem/dt/#{r[:gem]}?label=downloads&style=flat-square&color=brightgreen)"
      lines << "#{dl_badge} #{link} #{commit_badge}"
    else
      lines << "#{link} #{commit_badge}"
    end
  end

  lines << ""
  other_count = totals[:repos] - CURATED_REPOS.length
  lines << "and #{other_count} other repositories"
  lines << ""
  lines << %(</td><td>)
  lines << ""
  lines << %(<img src="#{IMG_PREFIX}/stats.svg" alt="Activity overview" />)
  lines << ""
  lines << %(</td></tr></table>)
  lines.join("\n")
end

README_PATH = File.expand_path("../README.md", __dir__)

MARKER_BEGIN = "<!-- CONTRIBUTIONS BEGIN -->"
MARKER_END   = "<!-- CONTRIBUTIONS END -->"

def update_readme(year_data, totals)
  content = File.read(README_PATH)

  unless content.include?(MARKER_BEGIN) && content.include?(MARKER_END)
    warn "  README.md missing CONTRIBUTIONS markers, skipping"
    return
  end

  formatted_total = format_count(totals[:contributions])

  snippet = []
  snippet << "#{formatted_total} contributions in total"
  snippet << ""
  snippet << readme_snippet(year_data)
  snippet << ""
  snippet << activity_overview(totals)

  replacement = "#{MARKER_BEGIN}\n#{snippet.join("\n")}\n#{MARKER_END}"
  updated = content.sub(/#{Regexp.escape(MARKER_BEGIN)}.*?#{Regexp.escape(MARKER_END)}/m, replacement)
  File.write(README_PATH, updated)
  warn "  README.md updated"
end

# --- main ---

def main
  year_data, totals = load_data
  if year_data.empty?
    warn "No data in #{DATA_DIR}. Run fetch_contributions.rb first."
    exit 1
  end

  all_counts = year_data.flat_map { |_, months| (1..12).map { |m| months[m] || 0 } }
  thresholds = compute_thresholds(all_counts)

  year_data.each_with_index do |(year, months), i|
    path = File.join(OUT_DIR, "#{year}.svg")
    File.write(path, year_svg(year, months, thresholds, show_label: (i % 2 == 0), first: (i == 0)))
    warn "  #{path}"
  end

  File.write(File.join(OUT_DIR, "stats.svg"), stats_svg(totals))
  warn "  stats.svg"

  update_readme(year_data, totals)

  warn "Done. #{year_data.length} year SVGs generated."
end

main
